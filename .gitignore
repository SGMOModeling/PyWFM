.ipynb_checkpoints/
*-checkpoint.ipynb
.vscode/
settings.json
__pycache__/
*.pyc
src/pywfm.egg-info/*
src/iwfm_pywfm.egg-info/*
dist/
build/
.pytest_cache/

# Test fixtures: Results/ is auto-generated by the conftest fixture
# from vendored inputs. Same with the .bin/.log artifacts that IWFM
# writes alongside the inputs in Simulation/ during instantiation.
tests/data/sample_model/*/Results/
tests/data/sample_model/*/Simulation/*.bin
tests/data/sample_model/*/Simulation/*.log
tests/data/sample_model/*/Simulation/*.out
tests/data/sample_model/*/Simulation/fort.*
# But keep the vendored PreProcessor.bin — the 393e02e+ kernel won't
# instantiate without an existing preprocessor cache, and pywfm doesn't
# invoke the standalone PreProcessor_x64.exe from Python. Re-include it.
!tests/data/sample_model/*/Simulation/PreProcessor.bin